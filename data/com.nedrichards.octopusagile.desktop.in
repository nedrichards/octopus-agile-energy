[Desktop Entry]
Type=Application
Name=Agile Rates
Comment=Track rates and usage for UK smart electricity tariffs
Exec=@APP_EXEC@
Icon=@APP_ICON@
Terminal=false
Categories=Utility;Finance;Office;
Keywords=energy;electricity;prices;tariffs;agile;go;intelligent;chart;usage;
StartupNotify=true
Actions=Preferences;

[Desktop Action Preferences]
Name=Preferences
Exec=@APP_EXEC@ --gapplication-service app.preferences
