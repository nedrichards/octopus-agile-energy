[Desktop Entry]
Type=Application
Name=Octopus Electricity Prices
Comment=Track live Octopus Energy electricity prices across supported tariffs
Exec=@APP_EXEC@
Icon=@APP_ICON@
Terminal=false
Categories=Utility;Finance;Office;
