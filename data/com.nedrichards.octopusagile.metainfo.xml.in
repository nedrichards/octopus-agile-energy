<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.nedrichards.octopusagile</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Agile Rates</name>
  <summary>Rates and usage for UK smart electricity tariffs</summary>
  <description>
    <p>Follow current and upcoming half-hour electricity rates, usage history, and estimated spend for supported Octopus Energy electricity tariffs in the UK.</p>
    <p>Check the current rate at a glance, and find the cheapest time to run appliances or charge devices.</p>
    <p>This app is independent and is not affiliated with, endorsed by, or sponsored by Octopus Energy.</p>
  </description>

  <developer id="com.nedrichards">
    <name>Nick Richards</name>
  </developer>

  <!-- Required: Should be a link to the upstream homepage for the component -->
  <url type="homepage">https://www.nedrichards.com/2026/05/agile-rates-after-launch/</url>
  <!-- Recommended: It is highly recommended for open-source projects to display the source code repository -->
  <url type="vcs-browser">https://github.com/nedrichards/octopus-agile-energy</url>
  <!-- Should point to the software's bug tracking system, for users to report new bugs -->
  <url type="bugtracker">https://github.com/nedrichards/octopus-agile-energy/issues</url>

  <translation type="gettext">octopusagile</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">com.nedrichards.octopusagile.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#e7c67a</color>
    <color type="primary" scheme_preference="dark">#7a551e</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nedrichards/octopus-agile-energy/3399f48bf479f2ecf63baa66fa052a5dd4505451/data/octopus-agile-screenshot.png</image>
      <caption>View current and upcoming prices</caption>
    </screenshot>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nedrichards/octopus-agile-energy/3399f48bf479f2ecf63baa66fa052a5dd4505451/data/octopus-agile-screenshot-find.png</image>
      <caption>Find the cheapest time</caption>
    </screenshot>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nedrichards/octopus-agile-energy/3399f48bf479f2ecf63baa66fa052a5dd4505451/data/octopus-agile-screenshot-small.png</image>
      <caption>Scale to any screen size</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.12" date="2026-05-13">
      <description>
        <p>This release improves cheapest-time planning and chart presentation.</p>
        <ul>
          <li>Add a finish countdown for appliances with finish-at timers</li>
          <li>Condense cheapest-time results into a clearer summary layout</li>
          <li>Label the selected cheapest window on the price chart</li>
          <li>Use the GNOME accent color for usage chart bars</li>
          <li>Add a source code link to the About window</li>
        </ul>
      </description>
    </release>
    <release version="1.0.11" date="2026-05-11">
      <description>
        <p>This release adds first-run setup, usage history, and estimated spend insights.</p>
        <ul>
          <li>Add a setup assistant with account-based setup and manual tariff selection</li>
          <li>Add usage history charts with kWh, energy spend, and total spend views</li>
          <li>Add historical spend estimates using tariff rates and standing charges</li>
          <li>Improve usage refresh behaviour with cache-first background updates</li>
          <li>Rename the app to Agile Rates and clarify its independent status</li>
        </ul>
      </description>
    </release>
    <release version="1.0.10" date="2026-03-22">
      <description>
        <p>This release refreshes the app's public branding and iconography.</p>
        <ul>
          <li>Redesign the app icon with a more balanced footprint and clearer small-size readability</li>
          <li>Update Flathub brand colors to better match the icon and improve listing presentation</li>
          <li>Rename the app to reflect support for multiple tariffs</li>
        </ul>
      </description>
    </release>
    <release version="1.0.9" date="2026-03-22">
      <description>
        <p>This release improves planning tools and makes the interface adapt more cleanly across screen sizes.</p>
        <ul>
          <li>Improve the chart with clearer labels, day boundaries, and adaptive sizing</li>
          <li>Improve adaptive window layouts across screen sizes</li>
          <li>Auto-scroll the chart to the selected cheapest time window</li>
          <li>Make the preferences window work better on narrow screens</li>
          <li>Harden refresh and error handling so displayed prices stay in sync</li>
        </ul>
      </description>
    </release>
    <release version="1.0.8" date="2026-03-21">
      <description>
        <ul>
          <li>Add adaptive horizontal grid lines and price labels to the chart</li>
          <li>Add a day transition indicator to the forecast chart</li>
          <li>Refine current price highlight for better visual clarity</li>
          <li>Improve chart layout and margins</li>
          <li>Update documentation and forecast range information</li>
          <li>Fix duplicate shortcut action registration and ensure tariff title updates correctly</li>
          <li>Prevent stale background refreshes from overwriting newer data</li>
          <li>Harden error display and cache cleanup logging</li>
          <li>Add unit tests for pricing and tariff selection logic</li>
        </ul>
      </description>
    </release>
    <release version="1.0.7" date="2026-03-09">
      <description translate="no">
        <p>This release includes the highly-requested average price calculation alongside finding the cheapest time to use electricity.</p>
        <ul>
          <li>Added an average price calculation metric in the Find Cheapest Time feature to help save money efficiently.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.6" date="2026-02-28">
      <description translate="no">
        <p>This release introduces new tariff types and other small improvements. Thanks to Andy Piper.</p>
        <ul>
          <li>Added support for multiple tariffs: Agile, Go, and Intelligent Go.</li>
          <li>Bug fixes and other UI improvements.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.5" date="2025-10-18">
      <description translate="no">
        <p>This release includes several bug fixes and improvements to the user experience.</p>
        <ul>
          <li>Added a feature to find the cheapest time to use electricity.</li>
          <li>Improved the UI of the find cheapest time feature.</li>
          <li>Updated the copy in the application for clarity and style.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.4" date="2025-08-02">
      <description translate="no">
        <p>This release includes several bug fixes and improvements to the user experience.</p>
        <ul>
          <li>The application will now open the preferences window on first run to allow the user to select a tariff.</li>
          <li>The main window will now refresh when the preferences window is closed.</li>
          <li>The error message is now cleared when a new refresh is initiated.</li>
          <li>The cache is now cleaned up on startup.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.3" date="2025-07-27">
      <description translate="no">
        <p>Fixes contrast of text in dark mode.</p>
      </description>
    </release>
    <release version="1.0.2" date="2025-07-01">
      <description translate="no">
        <p>This release includes several bug fixes and improvements to the user experience.</p>
        <ul>
          <li>Fixed an issue where the application would not launch from the desktop.</li>
          <li>The application now automatically refreshes when the window becomes visible.</li>
          <li>The application icon is now displayed in the about dialog.</li>
          <li>The last updated time is now correctly aligned.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2025-06-25">
      <description translate="no">
        <p>Initial version</p>
      </description>
    </release>
  </releases>

</component>
